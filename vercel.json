{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://lucidframe-3.onrender.com/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://lucidframe-3.onrender.com/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
