# ── Dependencies (root frontend + backend, any nested path) ──
node_modules/
**/node_modules/

# ── Build output ──
dist/
dist-ssr/
backend/dist/

# ── Environment / secrets (never commit real keys) ──
.env
.env.*
!.env.example
!**/.env.example
backend/.env

# ── User uploads (keep empty folder only) ──
backend/uploads/**
!backend/uploads/.gitkeep

# ── Legacy duplicate folder (if present) ──
LucidFrame/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor / OS ──
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db
.env